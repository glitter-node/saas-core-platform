APP_NAME=your-app-name
APP_ENV=local
APP_PORT=8000
APP_DOMAIN=app.local
STATIC_ROOT_PATH=app/web/static
ASSETS_ROOT_PATH=/path/to/assets
APP_DEBUG=false
ENABLE_DOCS=true
DEV_AUTH_ENABLED=false
DEV_ADMIN_AUTH_ENABLED=false
ALLOWED_HOSTS=127.0.0.1,localhost,app.local,*.app.local
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
DATABASE_URL=mysql+pymysql://app_user:app_password@127.0.0.1:3306/app_database
REDIS_URL=redis://127.0.0.1:6379/0
SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14
MAGIC_LINK_EXPIRE_MINUTES=15
ADMIN_ACCESS_TOKEN_EXPIRE_MINUTES=15
ADMIN_REFRESH_TOKEN_EXPIRE_DAYS=14
JWT_ALGORITHM=HS256
ADMIN_JWT_SCOPE=admin
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=mailer@example.com
MAIL_PASSWORD=replace-with-mail-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME=Your App Name
STRIPE_SECRET_KEY=replace-with-stripe-secret-key
STRIPE_WEBHOOK_SECRET=replace-with-stripe-webhook-secret
STRIPE_PRICE_ID_PRO=replace-with-stripe-price-id-pro
STRIPE_PRICE_ID_ENTERPRISE=replace-with-stripe-price-id-enterprise
SUBSCRIPTION_EXPIRY_WARNING_DAYS=3
USAGE_WARNING_THRESHOLD_PERCENT=80
SCHEDULER_SUBSCRIPTION_EXPIRY_SCAN_MINUTES=60
ADMIN_API_KEY=replace-with-admin-api-key
