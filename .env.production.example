APP_NAME=multi_tenant_saas_subscription_platform
APP_ENV=production
APP_PORT=8000
APP_DOMAIN=example.com
STATIC_ROOT_PATH=/srv/multi_tenant_saas_subscription_platform/app/web/static
ASSETS_ROOT_PATH=/srv/multi_tenant_saas_subscription_platform/assets
APP_DEBUG=false
ENABLE_DOCS=false
DEV_AUTH_ENABLED=false
DEV_ADMIN_AUTH_ENABLED=false
ALLOWED_HOSTS=example.com,*.example.com
CORS_ALLOWED_ORIGINS=https://example.com
DATABASE_URL=mysql+pymysql://app_user:change_me_database_password@127.0.0.1:3306/app_database
REDIS_URL=redis://127.0.0.1:6379/0
SECRET_KEY=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14
MAGIC_LINK_EXPIRE_MINUTES=15
ADMIN_ACCESS_TOKEN_EXPIRE_MINUTES=15
ADMIN_REFRESH_TOKEN_EXPIRE_DAYS=14
JWT_ALGORITHM=HS256
ADMIN_JWT_SCOPE=admin
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=mailer@example.com
MAIL_PASSWORD=change_me_mail_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME=multi_tenant_saas_subscription_platform
STRIPE_SECRET_KEY=change_me_stripe_secret_key
STRIPE_WEBHOOK_SECRET=change_me_stripe_webhook_secret
STRIPE_PRICE_ID_PRO=change_me_stripe_price_id_pro
STRIPE_PRICE_ID_ENTERPRISE=change_me_stripe_price_id_enterprise
SUBSCRIPTION_EXPIRY_WARNING_DAYS=3
USAGE_WARNING_THRESHOLD_PERCENT=80
SCHEDULER_SUBSCRIPTION_EXPIRY_SCAN_MINUTES=60
ADMIN_API_KEY=change_me_admin_api_key
